# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# The password visitors must enter to view the trip. Only its SHA-256 hash
# is ever written to the built site (generated/site-config.js), not this
# plaintext value. If unset, the build falls back to the demo password
# "demo" so the template runs out of the box.
SITE_PASSWORD=change-me
